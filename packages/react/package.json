{
  "name": "pd-editor-react",
  "version": "1.1.2",
  "description": "React adapter for pd-editor-core Markdown editor",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pidan/pd-markdown-editor.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/pidan/pd-markdown-editor#readme",
  "bugs": {
    "url": "https://github.com/pidan/pd-markdown-editor/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "react",
    "codemirror",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js",
      "require": "./dist/headless.cjs"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pd-editor-core": "workspace:*",
    "pd-markdown": "^2.1.1",
    "pd-markdown-ui": "^1.1.1",
    "pd-shad-ui": "^2.0.0",
    "katex": "^0.16.45"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": ">=3.0.0 || insiders"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
