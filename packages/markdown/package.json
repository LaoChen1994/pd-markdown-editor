{
  "name": "pd-markdown",
  "version": "0.1.0",
  "description": "Framework-agnostic Markdown parsing & rendering",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "highlight.js": "^11.11.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
