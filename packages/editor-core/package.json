{
  "name": "pd-editor-core",
  "version": "1.0.0",
  "description": "Framework-agnostic Markdown editor engine powered by CodeMirror 6",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pidan/pd-markdown-editor.git",
    "directory": "packages/editor-core"
  },
  "homepage": "https://github.com/pidan/pd-markdown-editor#readme",
  "bugs": {
    "url": "https://github.com/pidan/pd-markdown-editor/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "codemirror",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pd-markdown": "^2.1.1",
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@codemirror/theme-one-dark": "^6.1.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
